NODE_ENV=development
PORT=4000
LOG_LEVEL=debug
DATABASE_URL=postgresql://nus:nus_local_password@localhost:5432/nus_express_template
JWT_TOKEN_SECRET=replace-with-a-long-random-secret

# Optional Docker Compose overrides
POSTGRES_USER=nus
POSTGRES_PASSWORD=nus_local_password
POSTGRES_DB=nus_express_template
POSTGRES_PORT=5432
ADMINER_PORT=8080
